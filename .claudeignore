# .claudeignore for @kajaril/sovereignty-scan-mcp
# Copy to repo root as `.claudeignore` at milestone M1.
#
# Patterns Claude Code MUST NOT read or modify in this repo. Working around
# this file is a flag — stop and ask if a task seems to need an excluded path.

# ---------------------------------------------------------------------------
# Secrets — never read, never write, never even acknowledge as paths to suggest
# ---------------------------------------------------------------------------
.env
.env.*
.dev.vars
.dev.vars.*
*.secret
*.secrets
*secret*
*credential*
*credentials*
*token*
*.key
*.pem
*.p12
*.pfx
*_rsa
*_dsa
*_ed25519
*_ecdsa

# ---------------------------------------------------------------------------
# Build artifacts and local state — read-only at most, but excluded to keep
# context clean and prevent accidental edits to generated output
# ---------------------------------------------------------------------------
node_modules/
.wrangler/
dist/
build/
out/
.cache/
.next/
.turbo/
coverage/
.nyc_output/
.vitest_cache/

# ---------------------------------------------------------------------------
# Git internals — use git commands, never edit refs directly
# ---------------------------------------------------------------------------
.git/
.gitattributes.local

# ---------------------------------------------------------------------------
# IDE and editor metadata — not relevant to the build, often contains
# environment-specific tokens (e.g., JetBrains datasource configs)
# ---------------------------------------------------------------------------
.vscode/
.idea/
.cursor/
*.swp
*.swo
.DS_Store

# ---------------------------------------------------------------------------
# OS and tooling temp files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.temp
.npm/
.yarn/
.pnpm-store/

# ---------------------------------------------------------------------------
# Append-only audit artifacts — new files allowed via the audit workflow,
# existing files are immutable evidence
# ---------------------------------------------------------------------------
audit/incidents/*
audit/v*-debt-audit.md

# ---------------------------------------------------------------------------
# Applied migrations — additive only, never edited in place
# Edits require a NEW migration file (0002_*.sql, etc.), not changes to 0001.
# ---------------------------------------------------------------------------
migrations/0001_providers.sql
migrations/0001_risk_scores.sql

# ---------------------------------------------------------------------------
# Anything else that looks like exfiltrated user data
# ---------------------------------------------------------------------------
*.dump
*.bak
*.backup
*.sql.gz
db-export-*
